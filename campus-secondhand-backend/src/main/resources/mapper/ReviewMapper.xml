<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.secondhand.mapper.ReviewMapper">

    <resultMap id="BaseResultMap" type="com.campus.secondhand.entity.Review">
        <id column="id" property="id"/>
        <result column="transaction_id" property="transactionId"/>
        <result column="reviewer_id" property="reviewerId"/>
        <result column="reviewed_id" property="reviewedId"/>
        <result column="rating" property="rating"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, transaction_id, reviewer_id, reviewed_id, rating, content, create_time
    </sql>

    <insert id="insert" parameterType="com.campus.secondhand.entity.Review" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO review (transaction_id, reviewer_id, reviewed_id, rating, content)
        VALUES (#{transactionId}, #{reviewerId}, #{reviewedId}, #{rating}, #{content})
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM review
        WHERE id = #{id}
    </select>

    <select id="selectByTransactionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM review
        WHERE transaction_id = #{transactionId}
    </select>

    <select id="selectByReviewedId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM review
        WHERE reviewed_id = #{reviewedId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByReviewerId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM review
        WHERE reviewer_id = #{reviewerId}
        ORDER BY create_time DESC
    </select>

    <select id="countByReviewedId" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM review
        WHERE reviewed_id = #{reviewedId}
    </select>

</mapper>